---
# Example non-secret defaults. Copy to a gitignored creds.yml for secrets:
#   cp inventory/group_vars/all.yml.example creds.yml

# rh_offline_token: "paste-offline-token-here"
# rh_username: "your-redhat-login"
# rh_password: "your-redhat-password"

artifacts_dir: "~/Documents/aap-subscription-artifacts"
allocation_name: aap-local
reuse_existing_allocation: true
create_allocation_if_missing: true
enable_simple_content_access: true
manifest_backend: rhsm_api
